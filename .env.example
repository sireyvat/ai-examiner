# Copy this file to ".env" and fill in your real key. Never commit ".env" to git.

# Which provider to use for the examiner's "brain": "openai" or "gemini"
LLM_PROVIDER=openai

# --- OpenAI (used if LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# --- Gemini (used if LLM_PROVIDER=gemini) ---
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-1.5-flash

# Port the local server runs on
PORT=3000
